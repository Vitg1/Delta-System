/* @Author Sr Mil Games */ //[I-S]LN=10;[I-E]
class DeltaConfig{ //[I-S]LN=11;[I-E]
    List<String> targets = new ArrayList<String>(); //[I-S]LN=12;[I-E]
    List<String> excludes = new ArrayList<String>(); //[I-S]LN=13;[I-E]
