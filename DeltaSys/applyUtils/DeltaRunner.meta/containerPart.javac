        ptbr.put("TIP_ODD_QUOTES","Aspas ímpares detectadas, isso pode quebrar o sistema"); //[I-S]LN=51;[I-E]
        ptbr.put("TIP_TOO_MANY_QUOTES","Muitas aspas emboladas, verifique se é intencional"); //[I-S]LN=52;[I-E]
         //[I-S]LN=53;[I-E]
