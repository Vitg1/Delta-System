        ptbr.put("NO_CHANGES", "Nenhuma alteração em %s"); //[I-S]LN=28;[I-E]
        ptbr.put("FORMAT", "Formatado: %s"); //[I-S]LN=29;[I-E]
        ptbr.put("TARGET_ADDED", "Target: %s"); //[I-S]LN=30;[I-E]
