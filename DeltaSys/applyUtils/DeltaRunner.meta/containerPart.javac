    List<String> uncommentLinesWith = new ArrayList<String>(); //[I-S]LN=15;[I-E]
    String onlyIfContains; //[I-S]LN=16;[I-E]
    boolean dryRun = false; //[I-S]LN=17;[I-E]
    boolean format= false; //[I-S]LN=18;[I-E]
    boolean auto = false; //[I-S]LN=19;[I-E]
    public String logs = "normal"; //[I-S]LN=20;[I-E]
    public String logsLang = "ptbr"; //[I-S]LN=21;[I-E]
    public String logPrefix = "[DELTA]"; //[I-S]LN=22;[I-E]
    boolean previewLines=false; //[I-S]LN=23;[I-E]
    List<DeltaReplaceRule> rules = new ArrayList<DeltaReplaceRule>(); //[I-S]LN=24;[I-E]
} //[I-S]LN=25;[I-E]
