                    if (l == null) continue; //[I-S]LN=204;[I-E]
 //[I-S]LN=205;[I-E]
                    String searchLine = config.caseSensitive ? l : l.toLowerCase(); //[I-S]LN=206;[I-E]
                    String sTokenSearch = config.caseSensitive ? startToken : startToken.toLowerCase(); //[I-S]LN=207;[I-E]
                    String eTokenSearch = config.caseSensitive ? endToken : endToken.toLowerCase(); //[I-S]LN=208;[I-E]
 //[I-S]LN=209;[I-E]
