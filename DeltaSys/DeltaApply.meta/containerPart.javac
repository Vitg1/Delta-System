class DeltaApply { //[I-S]LN=6;[I-E]
  public static boolean matchTarget(File file, String target) { //[I-S]LN=7;[I-E]
    if (file == null || target == null) return false; //[I-S]LN=8;[I-E]
    String name = file.getName(); //[I-S]LN=9;[I-E]
    target = target.trim(); //[I-S]LN=10;[I-E]
    if (target.startsWith("[") && target.endsWith("]")) { //[I-S]LN=11;[I-E]
      target = target.substring(1, target.length() - 1).trim(); //[I-S]LN=12;[I-E]
    } //[I-S]LN=13;[I-E]
 //[I-S]LN=14;[I-E]
    if (target.startsWith("\"") && target.endsWith("\"")) { //[I-S]LN=15;[I-E]
      target = target.substring(1, target.length() - 1); //[I-S]LN=16;[I-E]
    } //[I-S]LN=17;[I-E]
 //[I-S]LN=18;[I-E]
    String base = new File(Directories.getProjectFolder() + "/Files/").getAbsolutePath().replace("\\", "/"); //[I-S]LN=19;[I-E]
    String path = file.getAbsolutePath().replace("\\", "/"); //[I-S]LN=20;[I-E]
    String relative = path.replace(base, ""); //[I-S]LN=21;[I-E]
    if (relative.startsWith("/")) { //[I-S]LN=22;[I-E]
      relative = relative.substring(1); //[I-S]LN=23;[I-E]
    } //[I-S]LN=24;[I-E]
 //[I-S]LN=25;[I-E]
    if (target.startsWith("*.")) { //[I-S]LN=26;[I-E]
      return file.getName().endsWith(target.substring(1)); //[I-S]LN=27;[I-E]
    } //[I-S]LN=28;[I-E]
 //[I-S]LN=29;[I-E]
    if (target.contains("/*.")) { //[I-S]LN=30;[I-E]
      String folder = target.substring(0, target.indexOf("/*.")); //[I-S]LN=31;[I-E]
      String ext = target.substring(target.indexOf("*.") + 1); //[I-S]LN=32;[I-E]
      return relative.startsWith(folder + "/") && file.getName().endsWith(ext); //[I-S]LN=33;[I-E]
    } //[I-S]LN=34;[I-E]
 //[I-S]LN=35;[I-E]
    if (target.endsWith("/*")) { //[I-S]LN=36;[I-E]
      String folder = target.substring(0, target.length() - 2); //[I-S]LN=37;[I-E]
      return relative.startsWith(folder + "/"); //[I-S]LN=38;[I-E]
    } //[I-S]LN=39;[I-E]
 //[I-S]LN=40;[I-E]
    return file.getName().equals(target); //[I-S]LN=41;[I-E]
  } //[I-S]LN=42;[I-E]
 //[I-S]LN=43;[I-E]
  public static boolean matchExclude(File file, List<String> excludes) { //[I-S]LN=44;[I-E]
    for (int i = 0; i < excludes.size(); i++) { //[I-S]LN=45;[I-E]
      if (matchTarget(file, excludes.get(i))) { //[I-S]LN=46;[I-E]
        return true; //[I-S]LN=47;[I-E]
      } //[I-S]LN=48;[I-E]
    } //[I-S]LN=49;[I-E]
    return false; //[I-S]LN=50;[I-E]
  } //[I-S]LN=51;[I-E]
 //[I-S]LN=52;[I-E]
  static String supremeFormat(String text) { //[I-S]LN=53;[I-E]
    if (text == null) return null; //[I-S]LN=54;[I-E]
    String[] lines = text.split("\n", -1); //[I-S]LN=55;[I-E]
    StringBuilder out = new StringBuilder(); //[I-S]LN=56;[I-E]
    int indentLevel = 0; //[I-S]LN=57;[I-E]
    String indentStr = "    "; //[I-S]LN=58;[I-E]
    boolean lastLineEmpty = false; //[I-S]LN=59;[I-E]
    for (String rawLine : lines) { //[I-S]LN=60;[I-E]
      String line = rawLine.trim(); //[I-S]LN=61;[I-E]
      if (line.isEmpty()) { //[I-S]LN=62;[I-E]
        lastLineEmpty = true; //[I-S]LN=63;[I-E]
        continue; //[I-S]LN=64;[I-E]
      } //[I-S]LN=65;[I-E]
 //[I-S]LN=66;[I-E]
      if (line.startsWith("}")) { //[I-S]LN=67;[I-E]
        indentLevel = Math.max(0, indentLevel - 1); //[I-S]LN=68;[I-E]
      } //[I-S]LN=69;[I-E]
 //[I-S]LN=70;[I-E]
      for (int j = 0; j < indentLevel; j++) { //[I-S]LN=71;[I-E]
        out.append(indentStr); //[I-S]LN=72;[I-E]
      } //[I-S]LN=73;[I-E]
 //[I-S]LN=74;[I-E]
      line = line.replaceAll("\\b(if|for|while|switch|catch)\\(", "$1 ("); //[I-S]LN=75;[I-E]
      line = line.replaceAll("\\s+([;\\{])", "$1"); //[I-S]LN=76;[I-E]
      out.append(line).append("\n"); //[I-S]LN=77;[I-E]
      if (line.endsWith("{")) indentLevel++; //[I-S]LN=78;[I-E]
      if (line.startsWith("}") && !lastLineEmpty) { //[I-S]LN=79;[I-E]
        out.append("\n"); //[I-S]LN=80;[I-E]
        lastLineEmpty = true; //[I-S]LN=81;[I-E]
      } else lastLineEmpty = false; //[I-S]LN=82;[I-E]
    } //[I-S]LN=83;[I-E]
    return out.toString(); //[I-S]LN=84;[I-E]
  } //[I-S]LN=85;[I-E]
 //[I-S]LN=86;[I-E]
 //[I-S]LN=87;[I-E]
// ----------------- APLICAR DELTA (versão melhorada) ----------------- //[I-S]LN=88;[I-E]
public static void applyDeltaToFile(File file, DeltaConfig config) { //[I-S]LN=89;[I-E]
    if (file == null || config == null) return; //[I-S]LN=90;[I-E]
    log(config, "debug", "APPLY_DELTA", file.getName()); //[I-S]LN=91;[I-E]
 //[I-S]LN=92;[I-E]
    try { //[I-S]LN=93;[I-E]
       // Proteção interna: nunca processar arquivos do sistema //[I-S]LN=94;[I-E]
        if (matchTarget(file, "DeltaSys/*")) { //[I-S]LN=95;[I-E]
            log(config, "debug", "SKIP_INTERNAL", file.getName()); //[I-S]LN=96;[I-E]
            return; //[I-S]LN=97;[I-E]
        } //[I-S]LN=98;[I-E]
 //[I-S]LN=99;[I-E]
        // Proteção por tamanho (evita processar arquivos gigantes por engano) //[I-S]LN=100;[I-E]
        long maxBytes = 10 * 1024 * 1024; // 10 MB, ajuste se necessário //[I-S]LN=101;[I-E]
        if (file.length() > maxBytes) { //[I-S]LN=102;[I-E]
            log(config, "warn", "SKIP_LARGE_FILE", file.getName(), file.length()); //[I-S]LN=103;[I-E]
            return; //[I-S]LN=104;[I-E]
        } //[I-S]LN=105;[I-E]
 //[I-S]LN=106;[I-E]
        String original = FileLoader.loadTextFromFile(file); //[I-S]LN=107;[I-E]
        if (original == null) return; //[I-S]LN=108;[I-E]
 //[I-S]LN=109;[I-E]
        // SELEÇÃO DE ARQUIVO (onlyIfContains) - respeita Case Sensitivity //[I-S]LN=110;[I-E]
        if (config.onlyIfContains != null && !config.onlyIfContains.isEmpty()) { //[I-S]LN=111;[I-E]
            boolean found; //[I-S]LN=112;[I-E]
            if (config.caseSensitive) { //[I-S]LN=113;[I-E]
                found = original.contains(config.onlyIfContains); //[I-S]LN=114;[I-E]
            } else { //[I-S]LN=115;[I-E]
                found = original.toLowerCase().contains(config.onlyIfContains.toLowerCase()); //[I-S]LN=116;[I-E]
            } //[I-S]LN=117;[I-E]
 //[I-S]LN=118;[I-E]
            if (!found) { //[I-S]LN=119;[I-E]
                log(config, "debug", "SKIP_ONLYIF", file.getName()); //[I-S]LN=120;[I-E]
                return; //[I-S]LN=121;[I-E]
            } //[I-S]LN=122;[I-E]
        } //[I-S]LN=123;[I-E]
 //[I-S]LN=124;[I-E]
        String modified = original; //[I-S]LN=125;[I-E]
        int changes = 0; //[I-S]LN=126;[I-E]
 //[I-S]LN=127;[I-E]
        // ITERAR REGRAS //[I-S]LN=128;[I-E]
        for (int i = 0; i < config.rules.size(); i++) { //[I-S]LN=129;[I-E]
            DeltaReplaceRule rule = config.rules.get(i); //[I-S]LN=130;[I-E]
            if (rule == null || rule.from == null) continue; //[I-S]LN=131;[I-E]
 //[I-S]LN=132;[I-E]
            String from = rule.from; //[I-S]LN=133;[I-E]
            String to = rule.to == null ? "" : rule.to; //[I-S]LN=134;[I-E]
            String before = modified; //[I-S]LN=135;[I-E]
 //[I-S]LN=136;[I-E]
            // --- LÓGICA WILDCARD MULTI-LINE (....) --- //[I-S]LN=137;[I-E]
            if (from.contains("....")) { //[I-S]LN=138;[I-E]
                String[] parts = from.split("\\.\\.\\.\\.", -1); //[I-S]LN=139;[I-E]
                String startToken = parts.length > 0 ? parts[0] : ""; //[I-S]LN=140;[I-E]
                String endToken = parts.length > 1 ? parts[1] : ""; //[I-S]LN=141;[I-E]
 //[I-S]LN=142;[I-E]
                // Proteção: evitar '....' vazio que apaga o arquivo inteiro //[I-S]LN=143;[I-E]
                if (startToken.trim().isEmpty() && endToken.trim().isEmpty()) { //[I-S]LN=144;[I-E]
