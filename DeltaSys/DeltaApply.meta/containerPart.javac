                String eTokenSearch = config.caseSensitive ? endToken : endToken.toLowerCase(); //[I-S]LN=151;[I-E]
 //[I-S]LN=152;[I-E]
                int searchFrom = 0; //[I-S]LN=153;[I-E]
                boolean anyReplaced = false; //[I-S]LN=154;[I-E]
 //[I-S]LN=155;[I-E]
