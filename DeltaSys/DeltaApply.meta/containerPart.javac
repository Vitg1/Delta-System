                    if (s == -1) break; //[I-S]LN=159;[I-E]
 //[I-S]LN=160;[I-E]
                    int e; //[I-S]LN=161;[I-E]
                    if (!eTokenSearch.isEmpty()) { //[I-S]LN=162;[I-E]
                        int offset = s + sTokenSearch.length(); //[I-S]LN=163;[I-E]
                        int relativeE = searchText.indexOf(eTokenSearch, offset); //[I-S]LN=164;[I-E]
