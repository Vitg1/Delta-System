        File bak = new File(file.getAbsolutePath() + ".bak"); //[I-S]LN=306;[I-E]
        FileLoader.exportTextToFile(original, bak); //[I-S]LN=307;[I-E]
        log(config, "debug", "BACKUP_CREATED", bak.getName()); //[I-S]LN=308;[I-E]
    } catch (Exception be) { //[I-S]LN=309;[I-E]
        log(config, "warn", "BACKUP_FAILED", file.getName()); //[I-S]LN=310;[I-E]
    } //[I-S]LN=311;[I-E]
} //[I-S]LN=312;[I-E]
                FileLoader.exportTextToFile(modified, file); //[I-S]LN=313;[I-E]
                log(config, "normal", "DELTA_APPLIED", file.getName(), changes); //[I-S]LN=314;[I-E]
            } //[I-S]LN=315;[I-E]
        } else { //[I-S]LN=316;[I-E]
            log(config, "debug", "NO_CHANGES", file.getName()); //[I-S]LN=317;[I-E]
        } //[I-S]LN=318;[I-E]
 //[I-S]LN=319;[I-E]
        if (config.format && !config.dryRun) { //[I-S]LN=320;[I-E]
            modified = supremeFormat(modified); //[I-S]LN=321;[I-E]
            FileLoader.exportTextToFile(modified, file); //[I-S]LN=322;[I-E]
            log(config, "debug", "FORMAT", file.getName()); //[I-S]LN=323;[I-E]
        } //[I-S]LN=324;[I-E]
 //[I-S]LN=325;[I-E]
    } catch (Exception e) { //[I-S]LN=326;[I-E]
        Terminal.log(e); //[I-S]LN=327;[I-E]
    } //[I-S]LN=328;[I-E]
} //[I-S]LN=329;[I-E]
 //[I-S]LN=330;[I-E]
 //[I-S]LN=331;[I-E]
 //[I-S]LN=332;[I-E]
// Método auxiliar robusto para substituição Case-Insensitive //[I-S]LN=333;[I-E]
public static String replaceIgnoreCase(String text, String search, String replacement) { //[I-S]LN=334;[I-E]
    if (text == null || search == null || search.isEmpty()) return text; //[I-S]LN=335;[I-E]
    if (replacement == null) replacement = ""; //[I-S]LN=336;[I-E]
 //[I-S]LN=337;[I-E]
    String lowerText = text.toLowerCase(); //[I-S]LN=338;[I-E]
    String lowerSearch = search.toLowerCase(); //[I-S]LN=339;[I-E]
    int start = 0; //[I-S]LN=340;[I-E]
    int index = lowerText.indexOf(lowerSearch, start); //[I-S]LN=341;[I-E]
 //[I-S]LN=342;[I-E]
    if (index == -1) return text; //[I-S]LN=343;[I-E]
 //[I-S]LN=344;[I-E]
    StringBuilder result = new StringBuilder(); //[I-S]LN=345;[I-E]
    while (index != -1) { //[I-S]LN=346;[I-E]
        result.append(text, start, index); //[I-S]LN=347;[I-E]
        result.append(replacement); //[I-S]LN=348;[I-E]
        start = index + search.length(); //[I-S]LN=349;[I-E]
        index = lowerText.indexOf(lowerSearch, start); //[I-S]LN=350;[I-E]
    } //[I-S]LN=351;[I-E]
 //[I-S]LN=352;[I-E]
    result.append(text.substring(start)); //[I-S]LN=353;[I-E]
    return result.toString(); //[I-S]LN=354;[I-E]
} //[I-S]LN=355;[I-E]
 //[I-S]LN=356;[I-E]
  // ----------------- PARSE DELTA (versão melhorada: boolean parsing seguro e ensure exclude) ----------------- //[I-S]LN=357;[I-E]
public static DeltaConfig parseDelta(File deltaFile) { //[I-S]LN=358;[I-E]
    DeltaConfig config = new DeltaConfig(); //[I-S]LN=359;[I-E]
    if (deltaFile == null || !deltaFile.exists()) return config; //[I-S]LN=360;[I-E]
    List<String> separators = Arrays.asList(">>", "=>", ":::", "::", ","); //[I-S]LN=361;[I-E]
 //[I-S]LN=362;[I-E]
    try { //[I-S]LN=363;[I-E]
        String text = FileLoader.loadTextFromFile(deltaFile); //[I-S]LN=364;[I-E]
        String[] lines = text.split("\n"); //[I-S]LN=365;[I-E]
        for (int i = 0; i < lines.length; i++) { //[I-S]LN=366;[I-E]
            String raw = lines[i]; //[I-S]LN=367;[I-E]
            if (raw == null) continue; //[I-S]LN=368;[I-E]
            // Remove comentários inline (após # ou //) //[I-S]LN=369;[I-E]
            String line = raw.split("(#|//)", 2)[0].trim(); //[I-S]LN=370;[I-E]
            if (line.isEmpty()) continue; //[I-S]LN=371;[I-E]
            String cmd = line.toLowerCase(); //[I-S]LN=372;[I-E]
 //[I-S]LN=373;[I-E]
            // logs: //[I-S]LN=374;[I-E]
            if (cmd.startsWith("logs:")) { //[I-S]LN=375;[I-E]
                config.logs = cleanValue(line.substring("logs:".length())).toLowerCase(); //[I-S]LN=376;[I-E]
                continue; //[I-S]LN=377;[I-E]
            } //[I-S]LN=378;[I-E]
 //[I-S]LN=379;[I-E]
            // logprefix: //[I-S]LN=380;[I-E]
            if (cmd.startsWith("logprefix:")) { //[I-S]LN=381;[I-E]
                String p = cleanValue(line.substring("logprefix:".length())); //[I-S]LN=382;[I-E]
                if (!p.isEmpty()) config.logPrefix = p; //[I-S]LN=383;[I-E]
                continue; //[I-S]LN=384;[I-E]
            } //[I-S]LN=385;[I-E]
 //[I-S]LN=386;[I-E]
            // target: //[I-S]LN=387;[I-E]
            if (cmd.startsWith("target:")) { //[I-S]LN=388;[I-E]
                String[] split = line.substring("target:".length()).split(","); //[I-S]LN=389;[I-E]
                for (String t : split) { //[I-S]LN=390;[I-E]
                    String v = cleanValue(t); //[I-S]LN=391;[I-E]
                    if (!v.isEmpty()) { //[I-S]LN=392;[I-E]
                        config.targets.add(v); //[I-S]LN=393;[I-E]
                        log(config, "debug", "TARGET_ADDED", v); //[I-S]LN=394;[I-E]
                    } //[I-S]LN=395;[I-E]
                } //[I-S]LN=396;[I-E]
                continue; //[I-S]LN=397;[I-E]
            } //[I-S]LN=398;[I-E]
 //[I-S]LN=399;[I-E]
            // exclude: //[I-S]LN=400;[I-E]
            if (cmd.startsWith("exclude:")) { //[I-S]LN=401;[I-E]
                String[] split = line.substring("exclude:".length()).split(","); //[I-S]LN=402;[I-E]
                for (String e : split) { //[I-S]LN=403;[I-E]
                    String v = cleanValue(e); //[I-S]LN=404;[I-E]
                    if (!v.isEmpty()) { //[I-S]LN=405;[I-E]
                        config.excludes.add(v); //[I-S]LN=406;[I-E]
                        log(config, "debug", "EXCLUDE_ADDED", v); //[I-S]LN=407;[I-E]
                    } //[I-S]LN=408;[I-E]
                } //[I-S]LN=409;[I-E]
                continue; //[I-S]LN=410;[I-E]
            } //[I-S]LN=411;[I-E]
 //[I-S]LN=412;[I-E]
            // onlyifcontains: //[I-S]LN=413;[I-E]
            if (cmd.startsWith("onlyifcontains:")) { //[I-S]LN=414;[I-E]
                config.onlyIfContains = cleanValue(line.substring("onlyifcontains:".length())); //[I-S]LN=415;[I-E]
                log(config, "debug", "ONLYIF_SET", config.onlyIfContains); //[I-S]LN=416;[I-E]
                continue; //[I-S]LN=417;[I-E]
            } //[I-S]LN=418;[I-E]
 //[I-S]LN=419;[I-E]
            // dryrun: //[I-S]LN=420;[I-E]
            if (cmd.startsWith("dryrun:")) { //[I-S]LN=421;[I-E]
                config.dryRun = cleanValue(line.substring("dryrun:".length())).equalsIgnoreCase("true"); //[I-S]LN=422;[I-E]
                continue; //[I-S]LN=423;[I-E]
            } //[I-S]LN=424;[I-E]
 //[I-S]LN=425;[I-E]
            // previewlines: //[I-S]LN=426;[I-E]
            if (cmd.startsWith("previewlines:")) { //[I-S]LN=427;[I-E]
                config.previewLines = cleanValue(line.substring("previewlines:".length())).equalsIgnoreCase("true"); //[I-S]LN=428;[I-E]
                continue; //[I-S]LN=429;[I-E]
            } //[I-S]LN=430;[I-E]
 //[I-S]LN=431;[I-E]
            // logslang: //[I-S]LN=432;[I-E]
            if (cmd.startsWith("logslang:")) { //[I-S]LN=433;[I-E]
                config.logsLang = cleanValue(line.substring("logslang:".length())); //[I-S]LN=434;[I-E]
                continue; //[I-S]LN=435;[I-E]
            } //[I-S]LN=436;[I-E]
 //[I-S]LN=437;[I-E]
 //[I-S]LN=438;[I-E]
// backup: //[I-S]LN=439;[I-E]
if (cmd.startsWith("backup:")) { //[I-S]LN=440;[I-E]
    config.createBackup = cleanValue(line.substring("backup:".length())) //[I-S]LN=441;[I-E]
            .equalsIgnoreCase("true"); //[I-S]LN=442;[I-E]
    continue; //[I-S]LN=443;[I-E]
} //[I-S]LN=444;[I-E]
            // format: //[I-S]LN=445;[I-E]
            if (cmd.startsWith("format:")) { //[I-S]LN=446;[I-E]
                config.format = cleanValue(line.substring("format:".length())).equalsIgnoreCase("true"); //[I-S]LN=447;[I-E]
                continue; //[I-S]LN=448;[I-E]
            } //[I-S]LN=449;[I-E]
 //[I-S]LN=450;[I-E]
            // auto: //[I-S]LN=451;[I-E]
            if (cmd.startsWith("auto:")) { //[I-S]LN=452;[I-E]
                config.auto = cleanValue(line.substring("auto:".length())).equalsIgnoreCase("true"); //[I-S]LN=453;[I-E]
                continue; //[I-S]LN=454;[I-E]
            } //[I-S]LN=455;[I-E]
 //[I-S]LN=456;[I-E]
            // casesensitive: //[I-S]LN=457;[I-E]
            if (cmd.startsWith("casesensitive:")) { //[I-S]LN=458;[I-E]
                config.caseSensitive = cleanValue(line.substring("casesensitive:".length())).equalsIgnoreCase("true"); //[I-S]LN=459;[I-E]
                continue; //[I-S]LN=460;[I-E]
            } //[I-S]LN=461;[I-E]
 //[I-S]LN=462;[I-E]
            // commentlineswith: //[I-S]LN=463;[I-E]
            if (cmd.startsWith("commentlineswith:")) { //[I-S]LN=464;[I-E]
                String[] split = line.substring("commentlineswith:".length()).split(","); //[I-S]LN=465;[I-E]
                for (String s : split) { //[I-S]LN=466;[I-E]
                    String keyword = cleanValue(s); //[I-S]LN=467;[I-E]
                    if (keyword != null && !keyword.isEmpty()) { //[I-S]LN=468;[I-E]
                        config.commentLinesWith.add(keyword); //[I-S]LN=469;[I-E]
                        log(config, "debug", "COMMENT_ADDED", keyword); //[I-S]LN=470;[I-E]
                    } //[I-S]LN=471;[I-E]
                } //[I-S]LN=472;[I-E]
                continue; //[I-S]LN=473;[I-E]
            } //[I-S]LN=474;[I-E]
 //[I-S]LN=475;[I-E]
            // uncommentlineswith: //[I-S]LN=476;[I-E]
            if (cmd.startsWith("uncommentlineswith:")) { //[I-S]LN=477;[I-E]
                String[] split = line.substring("uncommentlineswith:".length()).split(","); //[I-S]LN=478;[I-E]
                for (String s : split) { //[I-S]LN=479;[I-E]
                    String keyword = cleanValue(s); //[I-S]LN=480;[I-E]
                    if (keyword != null && !keyword.isEmpty()) { //[I-S]LN=481;[I-E]
                        config.uncommentLinesWith.add(keyword); //[I-S]LN=482;[I-E]
                        log(config, "debug", "UNCOMMENT_ADDED", keyword); //[I-S]LN=483;[I-E]
                    } //[I-S]LN=484;[I-E]
                } //[I-S]LN=485;[I-E]
                continue; //[I-S]LN=486;[I-E]
            } //[I-S]LN=487;[I-E]
 //[I-S]LN=488;[I-E]
            // remove: //[I-S]LN=489;[I-E]
            if (cmd.startsWith("remove:")) { //[I-S]LN=490;[I-E]
                String pattern = cleanValue(line.substring("remove:".length())); //[I-S]LN=491;[I-E]
                if (pattern != null && !pattern.isEmpty()) { //[I-S]LN=492;[I-E]
                    DeltaReplaceRule rule = new DeltaReplaceRule(); //[I-S]LN=493;[I-E]
                    rule.from = pattern; //[I-S]LN=494;[I-E]
                    rule.to = ""; //[I-S]LN=495;[I-E]
                    config.rules.add(rule); //[I-S]LN=496;[I-E]
                    log(config, "debug", "REMOVE_RULE", pattern); //[I-S]LN=497;[I-E]
                } //[I-S]LN=498;[I-E]
                continue; //[I-S]LN=499;[I-E]
            } //[I-S]LN=500;[I-E]
 //[I-S]LN=501;[I-E]
            // replace: //[I-S]LN=502;[I-E]
            if (cmd.startsWith("replace:")) { //[I-S]LN=503;[I-E]
                String body = line.substring("replace:".length()).trim(); //[I-S]LN=504;[I-E]
                String from = null; //[I-S]LN=505;[I-E]
                String to = null; //[I-S]LN=506;[I-E]
                Matcher m = Pattern.compile("\"((?:[^\"\\\\]|\\\\.)*)\"\\s+\"((?:[^\"\\\\]|\\\\.)*)\"").matcher(body); //[I-S]LN=507;[I-E]
                if (m.find()) { //[I-S]LN=508;[I-E]
                    from = m.group(1).replace("\\\"", "\""); //[I-S]LN=509;[I-E]
                    to = m.group(2).replace("\\\"", "\""); //[I-S]LN=510;[I-E]
                } //[I-S]LN=511;[I-E]
 //[I-S]LN=512;[I-E]
                if (from == null) { //[I-S]LN=513;[I-E]
                    for (String sep : separators) { //[I-S]LN=514;[I-E]
                        if (body.contains(sep)) { //[I-S]LN=515;[I-E]
                            String[] p = body.split(Pattern.quote(sep), 2); //[I-S]LN=516;[I-E]
                            if (p.length == 2) { //[I-S]LN=517;[I-E]
                                from = cleanValue(p[0]); //[I-S]LN=518;[I-E]
                                to = cleanValue(p[1]); //[I-S]LN=519;[I-E]
                            } //[I-S]LN=520;[I-E]
                            break; //[I-S]LN=521;[I-E]
                        } //[I-S]LN=522;[I-E]
                    } //[I-S]LN=523;[I-E]
                } //[I-S]LN=524;[I-E]
 //[I-S]LN=525;[I-E]
                if (from == null) { //[I-S]LN=526;[I-E]
                    from = cleanValue(body); //[I-S]LN=527;[I-E]
                    to = ""; //[I-S]LN=528;[I-E]
                } //[I-S]LN=529;[I-E]
 //[I-S]LN=530;[I-E]
                if (from == null || from.isEmpty()) { //[I-S]LN=531;[I-E]
                    log(config, "warn", "REPLACE_INVALID", (i + 1)); //[I-S]LN=532;[I-E]
                    continue; //[I-S]LN=533;[I-E]
                } //[I-S]LN=534;[I-E]
 //[I-S]LN=535;[I-E]
                if (to == null) to = ""; //[I-S]LN=536;[I-E]
                DeltaReplaceRule rule = new DeltaReplaceRule(); //[I-S]LN=537;[I-E]
                rule.from = from; //[I-S]LN=538;[I-E]
                rule.to = to; //[I-S]LN=539;[I-E]
                config.rules.add(rule); //[I-S]LN=540;[I-E]
                log(config, "debug", "REPLACE_ADDED", from, to); //[I-S]LN=541;[I-E]
                continue; //[I-S]LN=542;[I-E]
            } //[I-S]LN=543;[I-E]
 //[I-S]LN=544;[I-E]
            log(config, "debug", "LINE_IGNORED", line); //[I-S]LN=545;[I-E]
        } //[I-S]LN=546;[I-E]
 //[I-S]LN=547;[I-E]
    } catch (Exception e) { //[I-S]LN=548;[I-E]
        Terminal.log(e); //[I-S]LN=549;[I-E]
    } //[I-S]LN=550;[I-E]
 //[I-S]LN=551;[I-E]
    // Garantir exclude interno mesmo que usuário remova do arquivo //[I-S]LN=552;[I-E]
    if (!config.excludes.contains("DeltaSys/*")) { //[I-S]LN=553;[I-E]
        config.excludes.add(0, "DeltaSys/*"); //[I-S]LN=554;[I-E]
    } //[I-S]LN=555;[I-E]
 //[I-S]LN=556;[I-E]
    log(config, "normal", "PARSE_COMPLETE", config.rules.size()); //[I-S]LN=557;[I-E]
    return config; //[I-S]LN=558;[I-E]
} //[I-S]LN=559;[I-E]
 //[I-S]LN=560;[I-E]
  // ---------------- LIMPA VALORES (aspas e colchetes) //[I-S]LN=561;[I-E]
  static String cleanValue(String v) { //[I-S]LN=562;[I-E]
    if (v == null) return null; //[I-S]LN=563;[I-E]
    v = v.trim(); //[I-S]LN=564;[I-E]
    if (v.startsWith("\"") && v.endsWith("\"") && v.length() >= 2) v = v.substring(1, v.length() - 1); //[I-S]LN=565;[I-E]
    if (v.startsWith("[") && v.endsWith("]") && v.length() >= 2) v = v.substring(1, v.length() - 1); //[I-S]LN=566;[I-E]
    return v.trim(); //[I-S]LN=567;[I-E]
  } //[I-S]LN=568;[I-E]
 //[I-S]LN=569;[I-E]
  static void log(DeltaConfig config, String level, String key, Object... args) { //[I-S]LN=570;[I-E]
    if (config == null) return; //[I-S]LN=571;[I-E]
    // modo de log //[I-S]LN=572;[I-E]
    String mode = config.logs; //[I-S]LN=573;[I-E]
    if (mode == null) mode = "normal"; //[I-S]LN=574;[I-E]
    if (mode.equals("none")) return; //[I-S]LN=575;[I-E]
    if (mode.equals("normal") && level.equals("debug")) return; //[I-S]LN=576;[I-E]
    // prefixo //[I-S]LN=577;[I-E]
    String prefix = config.logPrefix; //[I-S]LN=578;[I-E]
    if (prefix == null || prefix.isEmpty()) prefix = "[DELTA]"; //[I-S]LN=579;[I-E]
    // seleciona idioma //[I-S]LN=580;[I-E]
    String lang = config.logsLang; //[I-S]LN=581;[I-E]
    if (lang == null || !LanguageManager.translations.containsKey(lang)) lang = "ptbr"; //[I-S]LN=582;[I-E]
    Map<String, String> dict = LanguageManager.translations.get(lang); //[I-S]LN=583;[I-E]
    String template = dict.getOrDefault(key, key); //[I-S]LN=584;[I-E]
    // formata a mensagem //[I-S]LN=585;[I-E]
    String message; //[I-S]LN=586;[I-E]
    try { //[I-S]LN=587;[I-E]
      message = String.format(template, args); //[I-S]LN=588;[I-E]
    } catch (Exception e) { //[I-S]LN=589;[I-E]
 //[I-S]LN=590;[I-E]
      message = template + " " + Arrays.toString(args); // fallback se der erro //[I-S]LN=591;[I-E]
    } //[I-S]LN=592;[I-E]
 //[I-S]LN=593;[I-E]
    Terminal.log(prefix + " " + message); //[I-S]LN=594;[I-E]
  } //[I-S]LN=595;[I-E]
 //[I-S]LN=596;[I-E]
  static void previewDiff(DeltaConfig config, String fileName, String original, String modified) { //[I-S]LN=597;[I-E]
    if (original == null || modified == null) return; //[I-S]LN=598;[I-E]
    String[] a = original.split("\n", -1); //[I-S]LN=599;[I-E]
    String[] b = modified.split("\n", -1); //[I-S]LN=600;[I-E]
    int max = Math.max(a.length, b.length); //[I-S]LN=601;[I-E]
    int changes = 0; //[I-S]LN=602;[I-E]
    log(config, "normal", "PREVIEW_FILE", fileName); //[I-S]LN=603;[I-E]
    for (int i = 0; i < max; i++) { //[I-S]LN=604;[I-E]
      String la = i < a.length ? a[i] : ""; //[I-S]LN=605;[I-E]
      String lb = i < b.length ? b[i] : ""; //[I-S]LN=606;[I-E]
      if (!la.equals(lb)) { //[I-S]LN=607;[I-E]
        changes++; //[I-S]LN=608;[I-E]
        String lineNumber = String.valueOf(i + 1); //[I-S]LN=609;[I-E]
        if (!la.isEmpty()) { //[I-S]LN=610;[I-E]
          Terminal.log(" " + lineNumber + " | - " + la); //[I-S]LN=611;[I-E]
        } //[I-S]LN=612;[I-E]
 //[I-S]LN=613;[I-E]
        if (!lb.isEmpty()) { //[I-S]LN=614;[I-E]
          Terminal.log(" " + lineNumber + " | + " + lb); //[I-S]LN=615;[I-E]
        } //[I-S]LN=616;[I-E]
 //[I-S]LN=617;[I-E]
        Terminal.log(""); // espaço visual //[I-S]LN=618;[I-E]
      } //[I-S]LN=619;[I-E]
    } //[I-S]LN=620;[I-E]
    if (changes == 0) { //[I-S]LN=621;[I-E]
      log(config, "normal", "PREVIEW_NO_CHANGES", fileName); //[I-S]LN=622;[I-E]
    } else { //[I-S]LN=623;[I-E]
 //[I-S]LN=624;[I-E]
      log(config, "normal", "PREVIEW_CHANGES_TOTAL", changes); //[I-S]LN=625;[I-E]
    } //[I-S]LN=626;[I-E]
  } //[I-S]LN=627;[I-E]
} //[I-S]LN=628;[I-E]