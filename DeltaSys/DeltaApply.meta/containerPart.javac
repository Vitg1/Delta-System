                        changes++; //[I-S]LN=176;[I-E]
                        anyReplaced = true; //[I-S]LN=177;[I-E]
                        // recomputa searchText e continua a busca logo após a substituição para evitar loops //[I-S]LN=178;[I-E]
                        searchText = config.caseSensitive ? modified : modified.toLowerCase(); //[I-S]LN=179;[I-E]
                        searchFrom = s + to.length(); //[I-S]LN=180;[I-E]
                    } else { //[I-S]LN=181;[I-E]
                        break; //[I-S]LN=182;[I-E]
                    } //[I-S]LN=183;[I-E]
                } //[I-S]LN=184;[I-E]
 //[I-S]LN=185;[I-E]
                if (anyReplaced) { //[I-S]LN=186;[I-E]
                    log(config, "debug", "MULTILINE_WILDCARD_HIT", from); //[I-S]LN=187;[I-E]
                } //[I-S]LN=188;[I-E]
 //[I-S]LN=189;[I-E]
                continue; // próxima regra //[I-S]LN=190;[I-E]
            } //[I-S]LN=191;[I-E]
 //[I-S]LN=192;[I-E]
            // --- LÓGICA WILDCARD LINHA-ÚNICA (...) --- //[I-S]LN=193;[I-E]
            if (from.contains("...")) { //[I-S]LN=194;[I-E]
                String[] parts = from.split("\\.\\.\\.", -1); //[I-S]LN=195;[I-E]
                String startToken = parts.length > 0 ? parts[0] : ""; //[I-S]LN=196;[I-E]
                String endToken = parts.length > 1 ? parts[1] : ""; //[I-S]LN=197;[I-E]
 //[I-S]LN=198;[I-E]
                String[] lines = modified.split("\n", -1); //[I-S]LN=199;[I-E]
                boolean lineModified = false; //[I-S]LN=200;[I-E]
 //[I-S]LN=201;[I-E]
                for (int li = 0; li < lines.length; li++) { //[I-S]LN=202;[I-E]
